{
  "name": "repoview",
  "private": true,
  "version": "1.3.6",
  "description": "Go from first import to safe code changes faster: onboard into unfamiliar repos, get grounded answers from your files, apply edits with review, and run tests without leaving one workspace.",
  "author": "Misterscan",
  "license": "MIT",
  "keywords": [
    "repository documentation",
    "code review",
    "AI assistant",
    "developer tools",
    "software development"
  ],
  "type": "module",
  "scripts": {
    "dev": "dotenvx run --overload -- tsx server/index.ts --dev",
    "build": "vite build",
    "preview": "dotenvx run -- tsx server/index.ts",
    "start": "dotenvx run --overload -- tsx server/index.ts",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "eslint . && tsc --noEmit",
    "lint:eslint": "eslint .",
    "lint:types": "tsc --noEmit",
    "logs:summarize": "tsx scripts/summarize-logs.ts"
  },
  "dependencies": {
    "@dotenvx/dotenvx-ops": "^0.37.8",
    "@google/genai": "^1.48.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/ws": "^8.18.1",
    "adm-zip": "^0.5.9",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "dotenvx-ops": "^0.0.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "multer": "^1.4.5-lts.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.20.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/adm-zip": "^0.5.8",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.6"
  }
}